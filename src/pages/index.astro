---
import { getUrl } from "src/utils/navigation";
import Html from "src/components/layout/Html.astro";
import PostCard from "src/components/PostCard.astro";
import RightArrow from "src/icons/lucide--arrow-right.svg";
import { getPosts, getPage, getImages } from "src/utils/collections";
import { render } from "astro:content";
import { MAX_POSTS_HOMEPAGE, MAX_IMAGES_HOMEPAGE } from "src/constants";
import ImageCard from "./images/_components/ImageCard.astro";

const homePage = await getPage("home");
const { title, summary } = homePage.data;
const { Content } = await render(homePage);

const posts = await getPosts({
  sort: "date",
  order: "desc",
});

const images = await getImages();

const latestPosts = posts.slice(0, MAX_POSTS_HOMEPAGE);
const latestImages = images.slice(
  0,
  Math.max(...Object.values(MAX_IMAGES_HOMEPAGE))
);
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<Html openGraph={{ title, description: summary }} data-page="Home">
  <div id="welcome">
    <h1>{title}</h1>
    <Content />
  </div>
  {
    latestImages.length > 0 && (
      <>
        <h2>
          {latestImages.length === images.length ? "Images" : "Latest images"}
        </h2>
        <div id="latest-images">
          {latestImages.map((image, index) => (
            <div
              class:list={{
                "hide-4": index >= MAX_IMAGES_HOMEPAGE.with4Columns,
                "hide-3": index >= MAX_IMAGES_HOMEPAGE.with3Columns,
                "hide-2": index >= MAX_IMAGES_HOMEPAGE.with2Columns,
                "hide-1": index >= MAX_IMAGES_HOMEPAGE.with1Column,
              }}
            >
              <ImageCard image={image} />
            </div>
          ))}
        </div>
        {latestImages.length !== images.length && (
          <a id="view-all" href={getUrl("/images")}>
            View all images <RightArrow width={16} height={16} />
          </a>
        )}
      </>
    )
  }
  {
    latestPosts.length > 0 && (
      <>
        <h2>
          {latestPosts.length === posts.length ? "Posts" : "Latest posts"}
        </h2>
        <div id="latest-post">
          {latestPosts.map((post) => (
            <div>
              <PostCard post={post} />
            </div>
          ))}
        </div>
        {latestPosts.length !== posts.length && (
          <a id="view-all" href={getUrl("/posts")}>
            View all posts <RightArrow width={16} height={16} />
          </a>
        )}
      </>
    )
  }
</Html>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-page="Home"] {
    display: flex;
    flex-direction: column;
    gap: 1em;

    & > #welcome {
      padding-inline: var(--middle-x-padding);
      max-width: 70ch;
      padding-top: 64px;
      margin-bottom: 16px;

      & > h1 {
        margin-bottom: 1em;
      }
    }

    & > h2 {
      margin-block: 0.5em;
      margin-top: 1em;
      padding-inline: var(--middle-x-padding);
    }

    & > #latest-images {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;

      & > div.hide-1,
      & > div.hide-2,
      & > div.hide-3 {
        display: inherit;
      }

      & > div.hide-4 {
        display: none;
      }

      @media only screen and (max-width: 768.5px) {
        grid-template-columns: repeat(3, 1fr);
        
        & > div.hide-1,
        & > div.hide-2,
        & > div.hide-4 {
          display: inherit;
        }

        & > div.hide-3 {
          display: none;
        }
      }

      @media only screen and (max-width: 450.5px) {
        grid-template-columns: repeat(2, 1fr);

        & > div.hide-1,
        & > div.hide-3,
        & > div.hide-4 {
          display: inherit;
        }

        & > div.hide-2 {
          display: none;
        }
      }

      @media only screen and (max-width: 300.5px) {
        grid-template-columns: repeat(1, 1fr);

        & > div.hide-2,
        & > div.hide-3,
        & > div.hide-4 {
          display: inherit;
        }

        & > div.hide-1 {
          display: none;
        }
      }
    }

    & > #latest-post {
      & > div {
        border-top: 1px solid var(--layout-border);
      }

      & > div:last-child {
        border-bottom: 1px solid var(--layout-border);
      }

      &:last-child {
        margin-bottom: 64px;
      }
    }

    & > #view-all {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 500;
      place-self: center;
      padding: 16px 24px;
      border-radius: 8px;
      margin-top: 16px;

      transition: background-color 100ms;

      & > svg {
        transition: translate 100ms;
      }

      &:hover,
      &:focus-visible {
        background-color: var(--foreground-10);

        & > svg {
          translate: 4px 0px;
        }
      }
    }
  }
</style>
