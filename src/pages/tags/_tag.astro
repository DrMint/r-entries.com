---
import Html from "src/components/layout/Html.astro";
import HashLogo from "src/icons/lucide--hash.svg";
import PostCard from "src/components/PostCard.astro";
import { getPosts, getImages } from "src/utils/collections";
import ImagesGrid from "src/pages/images/_components/ImagesGrid.astro";

interface Props {
  tag: string;
}

const { tag } = Astro.props;

const posts = await getPosts({ tag, sort: "date", order: "desc" });
const images = await getImages({ tag, sort: "date", order: "desc" });
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<Html data-page="Tag">
  <h1>
    Content tagged with{" "}
    <span>
      <HashLogo width={26} height={26} />
      {tag}
    </span>
  </h1>

  {
    posts.length > 0 && (
      <div id="posts">
        {posts!.map((post) => (
          <div>
            <PostCard post={post} />
          </div>
        ))}
      </div>
    )
  }

  {images.length > 0 && <ImagesGrid images={images} />}
</Html>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-page="Tag"] {
    display: flex;
    flex-direction: column;
    gap: 32px;

    padding-top: 64px;
    padding-bottom: 128px;

    & > h1 {
      padding-inline: var(--middle-x-padding);
      line-height: 1.5;

      & > span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: var(--foreground-10);
        border-radius: 100vmax;
        padding: 8px 14px;
        padding-right: 18px;
        font-size: var(--font-size-2xl);
        font-weight: 500;
      }
    }

    & > #posts {
      & > div {
        border-top: 1px solid var(--layout-border);
      }

      & > div:last-child {
        border-bottom: 1px solid var(--layout-border);
      }
    }

    & > #images {
      & > div {
        border-top: 1px solid var(--layout-border);
      }
    }
  }
</style>
