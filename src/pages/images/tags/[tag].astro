---
import { getImages, getTags } from "src/utils/collections";
import { getUrl } from "src/utils/navigation";
import ImagesGrid from "../_components/ImagesGrid.astro";
import EntriesPage from "src/components/layout/EntriesPage.astro";
import { ENABLE_TAG_FEATURE } from "src/constants";

export const getStaticPaths = async () => {
  if (!ENABLE_TAG_FEATURE) return [];

  const tags = await getTags({ collection: "images" });

  const paths: { params: { tag: string | undefined } }[] = tags.map(
    ({ tag }) => ({ params: { tag } })
  );

  return paths;
};

const activeTag = Astro.params.tag!;

const images = await getImages({ tag: activeTag });
const imageTags = await getTags({
  collection: "images",
  sort: "prevalence",
  order: "desc",
});
---

<EntriesPage
  title="Images"
  tags={imageTags}
  getTagLink={(tag) =>
    activeTag === tag ? getUrl(`/images`) : getUrl(`/images/tags/${tag}`)}
  activeTag={activeTag}
>
  <ImagesGrid images={images} />
</EntriesPage>
