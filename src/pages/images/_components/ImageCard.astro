---
import type { CollectionEntry } from "astro:content";
import { getUrl } from "src/utils/navigation";
import Image from "src/components/Image.astro";

interface Props {
  image: CollectionEntry<"images">;
}

const { image } = Astro.props;
---

<a data-component="ImageCard" href={getUrl(`/images/${image.id}`)}>
  <Image
    src={image.data.thumbnail ?? image.data.image}
    alt=""
    sizes="
      (max-width: 300px) 100vw,
      (max-width: 450px) 50vw,
      (max-width: 768px) 33vw,
      (max-width: 1024px) 25vw,
      256px"
    fallbackWidth={256}
    maxWidth={580}
    priority
    square
  />
</a>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-component="ImageCard"] {
    display: flex;
    flex-direction: column;
    gap: 32px;
    position: relative;

    overflow: hidden;
    outline: 1px solid transparent;

    transition: outline-color 100ms;

    &:hover,
    &:focus-visible {
      outline-color: var(--foreground-50);

      & > picture > img {
        scale: 110%;
      }
    }

    & > picture > img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      aspect-ratio: 1/1;

      transition: scale 500ms;

      background-image: radial-gradient(
        var(--layout-border) 20%,
        transparent 30%
      );
      background-size: 8px 8px;
      background-repeat: space;
    }
  }
</style>
