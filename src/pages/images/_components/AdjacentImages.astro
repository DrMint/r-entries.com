---
import type { CollectionEntry } from "astro:content";
import LeftArrow from "src/icons/lucide--arrow-left.svg";
import RightArrow from "src/icons/lucide--arrow-right.svg";
import { getUrl } from "src/utils/navigation";
import { getAdjacentImages } from "src/utils/collections";

interface Props {
  currentImage: CollectionEntry<"images">;
}

const { currentImage, ...rest } = Astro.props;
const { previousImage, nextImage } = await getAdjacentImages(currentImage);
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<div data-component="AdjacentImages" {...rest}>
  {
    nextImage ? (
      <a id="next" href={getUrl(`/images/${nextImage.id}`)}>
        <LeftArrow width={18} height={18} />
        <div>
          <p class="label">Next Image</p>
          <p>{nextImage.data.title}</p>
        </div>
      </a>
    ) : (
      <div id="next" class="disabled">
        <LeftArrow width={18} height={18} />
        <div>
          <p class="label">Next Image</p>
          <p>Newest image!</p>
        </div>
      </div>
    )
  }

  {
    previousImage ? (
      <a id="previous" href={getUrl(`/images/${previousImage.id}`)}>
        <div>
          <p class="label">Previous Image</p>
          <p>{previousImage.data.title}</p>
        </div>
        <RightArrow width={18} height={18} />
      </a>
    ) : (
      <div id="previous" class="disabled">
        <div>
          <p class="label">Previous Image</p>
          <p>Last image!</p>
        </div>
        <RightArrow width={18} height={18} />
      </div>
    )
  }
</div>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-component="AdjacentImages"] {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;

    & > #next,
    & > #previous {
      display: flex;
      border: 1px solid var(--foreground-20);
      border-radius: 8px;
      gap: 12px;
      padding: 16px;
      align-items: center;

      & .label {
        font-size: var(--font-size-s);
        color: var(--foreground-60);
      }

      &.disabled {
        border-color: var(--foreground-10);
        color: var(--foreground-50);
        cursor: not-allowed;

        & .label {
          color: var(--foreground-30);
        }
      }

      transition:
        background-color 100ms,
        border-color 100ms;

      & > svg {
        transition: translate 100ms;
      }

      &:not(.disabled):hover,
      &:not(.disabled):focus-visible {
        background-color: var(--foreground-5);
        border-color: var(--foreground-50);

        & > svg {
          translate: var(--translation) 0px;
        }
      }

      & > div {
        display: flex;
        flex-direction: column;
        gap: 4px;

        & p {
          line-height: 1.2;
        }
      }
    }

    & > #previous {
      justify-content: end;
      text-align: end;
      --translation: 4px;
      padding-left: 24px;
    }

    & > #next {
      --translation: -4px;
      padding-right: 24px;
    }

    @media (max-width: 600.5px) {
      grid-template-columns: 1fr;
    }

    @media (min-width: 1600.5px) {
      & > #next,
      & > #previous {
        position: fixed;
        --margin: calc((100vw - 1024px) * 0.07);
        max-width: calc((100vw - 1024px) / 2 - var(--margin) * 2);
        top: 50%;
      }

      & > #next {
        left: calc((100vw - 1024px) / 2 - var(--margin));
        transform: translateX(-100%);
      }

      & > #previous {
        right: calc((100vw - 1024px) / 2 - var(--margin));
        transform: translateX(100%);
      }
    }
  }
</style>
