---
import { getGalleryEntries } from "src/utils/collections";
import Index from "./_index.astro";
import Entry from "./_entry.astro";
import { ENABLE_GALLERY_FEATURE } from "src/constants";

export const getStaticPaths = async () => {
  if (!ENABLE_GALLERY_FEATURE) return [];
  const entries = await getGalleryEntries();

  return [
    { params: { slug: undefined } },
    ...entries.map(({ id }) => ({ params: { slug: id } })),
  ];
};

const slug = Astro.params.slug;
---

{slug ? <Entry slug={slug} /> : <Index />}
