---
import Html from "src/components/layout/Html.astro";
import { getGalleryEntries } from "src/utils/collections";
import GalleryEntryCard from "./_components/GalleryEntryCard.astro";

const entries = await getGalleryEntries();
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<Html data-page="Gallery">
  <h1>Gallery</h1>
  <div id="gallery">
    {
      entries.map((entry) => (
        <div>
          <GalleryEntryCard entry={entry} />
        </div>
      ))
    }
  </div>
</Html>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-page="Gallery"] {
    display: flex;
    flex-direction: column;
    gap: 32px;

    padding-top: 64px;
    padding-bottom: 128px;

    & > h1 {
      padding-inline: var(--middle-x-padding);
    }

    & > #gallery {
      display: grid;

      grid-template-columns: 1fr;

      @media only screen and (min-width: 300px) {
        grid-template-columns: repeat(2, 1fr);
      }

      @media only screen and (min-width: 450px) {
        grid-template-columns: repeat(3, 1fr);
      }

      @media only screen and (min-width: 768px) {
        grid-template-columns: repeat(4, 1fr);
      }

      gap: 1px;

      & > div {
        width: 100%;
        aspect-ratio: 1/1;
      }
    }
  }
</style>
