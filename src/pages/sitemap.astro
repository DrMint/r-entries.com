---
import Html from "src/components/layout/Html.astro";
import { getUrl } from "src/utils/navigation";
import { getImages, getPosts } from "src/utils/collections";
import { MAX_POSTS_HOMEPAGE, MAX_IMAGES_HOMEPAGE } from "src/constants";

const posts = await getPosts({ sort: "title", order: "asc" });
const images = await getImages({ sort: "title", order: "asc" });

const postsPageExists = MAX_POSTS_HOMEPAGE !== Infinity;
const imagesPageExists =
  Math.min(...Object.values(MAX_IMAGES_HOMEPAGE)) !== Infinity;
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<Html data-page="Sitemap">
  <h1>Sitemap</h1>
  <ul>
    <li>
      <a href={getUrl("/")}>Home</a>
    </li>
    {
      posts.length > 0 && (
        <li>
          {postsPageExists ? <a href={getUrl("/posts")}>Posts</a> : "Posts"}
          <ul>
            {posts.map((post) => (
              <li>
                <a href={getUrl(`/posts/${post.id}`)}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </li>
      )
    }
    {
      images.length > 0 && (
        <li>
          {imagesPageExists ? <a href={getUrl("/images")}>Images</a> : "Images"}
          <ul>
            {images.map((image) => (
              <li>
                <a href={getUrl(`/images/${image.id}`)}>{image.data.title}</a>
              </li>
            ))}
          </ul>
        </li>
      )
    }
    <li>
      <a href={getUrl("/about")}>About</a>
    </li>
    <li>
      Meta
      <ul>
        <li>
          <a href={getUrl("/rss.xml", true)}>RSS (XML)</a>
        </li>
        <li>
          <a href={getUrl("/sitemap-index.xml", true)}>Sitemap (XML)</a>
        </li>
        <li>
          <a href={getUrl("/sitemap")}>Sitemap (you are here)</a>
        </li>
      </ul>
    </li>
  </ul>
</Html>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-page="Sitemap"] {
    padding: 64px var(--middle-x-padding);

    & > h1 {
      margin-bottom: 1em;
    }

    ul {
      margin-block: 0.75em;
      padding-left: min(2.5em, 5vw);

      & > li {
        list-style: revert;
        padding-left: 3px;
      }

      & > li + li {
        margin-top: 0.5em;
      }

      ::marker {
        color: var(--foreground-50);
      }
    }

    a {
      color: revert;
    }
  }
</style>
