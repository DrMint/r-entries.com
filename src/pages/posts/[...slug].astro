---
import { MAX_POSTS_HOMEPAGE } from "src/constants";
import { getPosts } from "src/utils/collections";
import Post from "./_post.astro";
import Index from "./_index.astro";

export const getStaticPaths = async () => {
  const posts = await getPosts({ includingNested: true });

  const paths: { params: { slug: string | undefined } }[] = posts.map(
    (post) => ({
      params: { slug: post.id },
    })
  );

  if (MAX_POSTS_HOMEPAGE !== Infinity) {
    paths.push({ params: { slug: undefined } });
  }

  return paths;
};

const slug = Astro.params.slug;
---

{slug ? <Post slug={slug} /> : <Index />}
