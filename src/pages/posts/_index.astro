---
import EntriesPage from "src/components/layout/EntriesPage.astro";
import PostsRows from "./_components/PostsRows.astro";
import { getPosts, getTags } from "src/utils/collections";
import { getUrl } from "src/utils/navigation";

const posts = await getPosts({ sort: "date", order: "desc" });
const tags = await getTags({
  collection: "posts",
  sort: "prevalence",
  order: "desc",
});
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<EntriesPage
  title="Posts"
  tags={tags}
  getTagLink={(tag) => getUrl(`/posts/tags/${tag}`)}
>
  <PostsRows posts={posts} />
</EntriesPage>
