---
import type { CollectionEntry } from "astro:content";
import { getReadingTime } from "src/utils/readingTime";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post, ...rest } = Astro.props;
const { date } = post.data;
const readingTime = getReadingTime(post.body);
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<div data-component="PostMeta" {...rest}>
  <p>{date.toLocaleDateString("en-US", { dateStyle: "long" })}</p>
  <div class="separator"></div>
  <p>{`${readingTime} min read`}</p>
</div>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-component="PostMeta"] {
    display: flex;
    gap: 8px;
    align-items: center;
    color: var(--foreground-60);

    .separator {
      height: 1em;
      color: var(--foreground-20);
      width: 1px;
      background-color: var(--foreground-20);
      margin-inline: 0.1em;
    }
  }
</style>
