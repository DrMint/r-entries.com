---
import HashLogo from "src/icons/lucide--hash.svg";

interface Props {
  tag: string;
  count?: number | undefined;
  withLinks?: boolean;
  active?: boolean;
  large?: boolean;
}

const {
  tag,
  count,
  withLinks = false,
  active = false,
  large = false,
  ...rest
} = Astro.props;
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<div
  data-component="TagPill"
  class:list={{ "with-links": withLinks, active, large }}
  {...rest}
>
  <HashLogo width={large ? 16 : 12} height={large ? 16 : 12} />
  {tag}
  {count && <span>{`(${count})`}</span>}
</div>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  [data-component="TagPill"] {
    display: flex;
    align-items: center;
    gap: 2px;
    background-color: var(--foreground-10);
    border-radius: 100vmax;
    padding: 4px 8px;
    padding-right: 12px;

    font-family: monospace;
    font-size: var(--font-size-xs);
    letter-spacing: -5%;
    font-weight: 500;

    & > span {
      font-size: var(--font-size-s);
      color: var(--foreground-60);
    }

    &.with-links {
      border: 1px solid var(--foreground-10);

      transition:
        background-color 100ms,
        border-color 100ms;

      &:hover,
      &:focus-visible {
        background-color: transparent;
        border-color: var(--foreground-20);
      }
    }

    &.active {
      background-color: var(--foreground);
      border: 1px solid var(--foreground);
      color: var(--background);

      & > span {
        color: var(--foreground-50);
      }
    }

    &.large {
      font-size: var(--font-size-l);
      padding: 4px 12px;
      padding-right: 12px;
    }
  }
</style>
