---
import MdxImageImage from "src/components/mdx/MdxImageImage.astro";

interface Props {
  src: ImageMetadata;
  alt?: string;
  caption?: string | true;
}

const { src, alt, caption } = Astro.props;
const text = caption === true ? alt : caption;
---

{/* --------------------------------[ HTML ]-------------------------------- */}

<figure aria-hidden={text === undefined ? "true" : undefined}>
  <div aria-hidden={alt === undefined ? "true" : undefined}>
    <MdxImageImage src={src} alt={alt} />
  </div>
  {text && <figcaption>{caption === true ? alt : caption}</figcaption>}
</figure>

{/* ---------------------------------[ CSS ]-------------------------------- */}

<style>
  figure {
    margin: 0;
    margin-block: 2em;

    & > figcaption {
      margin-top: 0.75em;
      margin-bottom: 2em;
      color: var(--foreground-60);
      text-align: center;
    }
  }
</style>
